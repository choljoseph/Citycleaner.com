<!-- Contact Body -->
<div class="contact-body">
  <!-- Info -->
  <div class="fade-up">
    <p class="eyebrow">Contact Details</p>
    <h2 style="font-family:var(--font-display);font-size:1.8rem;letter-spacing:.04em;color:var(--navy-deep);margin-bottom:2rem;">Reach Us <span style="color:var(--accent)">Anytime</span></h2>

    <div class="ci-block">
      <div class="ci-lbl">📞 Phone</div>
      <div class="ci-val">+211 924 000 000</div>
    </div>
    <div class="ci-block">
      <div class="ci-lbl">💬 WhatsApp</div>
      <div class="ci-val">+211 924 000 000</div>
    </div>
    <div class="ci-block">
      <div class="ci-lbl">📧 Email</div>
      <div class="ci-val">info@citycleaners.ss</div>
    </div>
    <div class="ci-block">
      <div class="ci-lbl">📍 Location</div>
      <div class="ci-val">Juba, South Sudan<br><span style="font-size:.85rem;color:var(--text-soft);">Serving all areas of Juba</span></div>
    </div>
    <div class="ci-block">
      <div class="ci-lbl">🕐 Hours</div>
      <div class="ci-val">Mon – Sat: 7:00 AM – 7:00 PM<br>Sunday: 8:00 AM – 4:00 PM</div>
    </div>

    <div style="background:var(--navy-deep);border-radius:var(--radius-lg);padding:1.75rem;margin-top:2rem;">
      <div style="font-size:.68rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--accent-light);margin-bottom:.5rem;">AREAS WE SERVE</div>
      <p style="font-size:.875rem;color:rgba(255,255,255,.55);line-height:1.8;">Juba Town · Gudele · Munuki · Lologo · Thongpiny · Mia Saba · Konyokonyo · Atlabara · Gumbo and surrounding areas.</p>
    </div>

    <div style="background:var(--offwhite);border:1px solid var(--border);border-radius:var(--radius-lg);padding:1.75rem;margin-top:1rem;">
      <div style="font-family:var(--font-display);font-size:1rem;letter-spacing:.04em;color:var(--navy-deep);margin-bottom:.5rem;">SAME-DAY BOOKINGS</div>
      <div style="font-size:.875rem;color:var(--text-mid);line-height:1.7;">Need a clean urgently? WhatsApp or call us before noon and we'll do our best to send a team the same day.</div>
    </div>
  </div>

  <!-- Form -->
  <div class="fade-up">
    <p class="eyebrow">Booking Form</p>
    <h2 style="font-family:var(--font-display);font-size:1.8rem;letter-spacing:.04em;color:var(--navy-deep);margin-bottom:2rem;">Request a <span style="color:var(--accent)">Free Quote</span></h2>

    <form id="contact-form" novalidate>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="f-name">Your Name *</label>
          <input type="text" id="f-name" class="form-input" placeholder="Full name" required/>
        </div>
        <div class="form-group">
          <label class="form-label" for="f-phone">Phone Number</label>
          <input type="tel" id="f-phone" class="form-input" placeholder="+211 XXX XXX XXX"/>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label" for="f-email">Email Address *</label>
        <input type="email" id="f-email" class="form-input" placeholder="your@email.com" required/>
      </div>

      <div class="form-group">
        <label class="form-label" for="f-service">Service Needed</label>
        <select id="f-service" class="form-select">
          <option value="">Select a service...</option>
          <option>General House Cleaning</option>
          <option>Office &amp; Commercial Cleaning</option>
          <option>Carpet Cleaning</option>
          <option>Window Cleaning</option>
          <option>Upholstery Cleaning</option>
          <option>Move-In / Move-Out Clean</option>
          <option>Multiple Services / Not Sure</option>
        </select>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="f-type">Property Type</label>
          <select id="f-type" class="form-select">
            <option value="">Select...</option>
            <option>Home / Apartment</option>
            <option>Office / Commercial</option>
            <option>NGO / Organisation</option>
            <option>Restaurant / Cafe</option>
            <option>Other</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label" for="f-date">Preferred Date</label>
          <input type="date" id="f-date" class="form-input"/>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label" for="f-area">Your Area in Juba</label>
        <input type="text" id="f-area" class="form-input" placeholder="e.g. Gudele, Munuki, Juba Town..."/>
      </div>

      <div class="form-group">
        <label class="form-label" for="f-msg">Additional Details</label>
        <textarea id="f-msg" class="form-textarea" placeholder="Tell us anything else that's helpful — size of property, number of rooms, specific areas of concern..."></textarea>
      </div>

      <button type="submit" class="btn btn-accent" style="width:100%;justify-content:center;padding:1rem;font-size:.9rem;">
        Send Booking Request <span class="arr">→</span>
      </button>

      <div class="form-success" id="form-success">
        ✅ Thank you! Your booking request has been received. We'll contact you within a few hours to confirm your clean.
      </div>

      <p style="font-size:.78rem;color:var(--text-soft);margin-top:1rem;text-align:center;">
        Or WhatsApp us directly at <strong>0924 000 000</strong> for an instant response.
      </p>
    </form>
  </div>
</div>

